# Environment Variables Example
# Copy this to .env.local in each app directory and fill in your values

# ====================
# Landing Page
# apps/landing/.env.local
# ====================
VITE_PHOTO_SHARING_URL=https://d0987654321xyz.cloudfront.net


# ====================
# Photo Sharing Frontend
# apps/photo-sharing/frontend/.env.local
# ====================
VITE_API_BASE_URL=https://abc123.execute-api.us-east-1.amazonaws.com


# ====================
# How to get these values:
# ====================
# After deploying with Pulumi, run:
#   cd infra && pulumi stack output
#
# Then copy:
#   - photoFrontendUrl → VITE_PHOTO_SHARING_URL (for landing page)
#   - photoApiUrl → VITE_API_BASE_URL (for photo sharing frontend)
